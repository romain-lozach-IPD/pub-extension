{
  "manifest_version": 3,
  "name": "Side Panel Extension",
  "version": "1.0.0",
  "description": "Extension avec Side Panel pour Chrome",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["sidePanel", "storage", "scripting", "activeTab"],
  "host_permissions": ["http://localhost/*"],
  "action": {
    "default_title": "Ouvrir le panneau latéral"
  },
  "side_panel": {
    "default_path": "src/index.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
